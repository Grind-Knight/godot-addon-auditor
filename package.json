{
  "name": "godot-addon-auditor",
  "version": "0.1.1",
  "description": "A free CLI that checks Godot 4 add-ons for common release and Asset Library packaging issues.",
  "author": "Grind Knight",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "bin": {
    "godot-addon-auditor": "./src/cli.mjs"
  },
  "scripts": {
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test.ps1",
    "assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-assets.ps1",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package.ps1",
    "validate:good": "node src/cli.mjs examples/good-project",
    "validate:bad": "node src/cli.mjs examples/bad-project"
  },
  "keywords": [
    "godot",
    "godot4",
    "addon",
    "plugin",
    "asset-library",
    "game-dev",
    "cli"
  ]
}
